# =============================================================
# n8n AI Email Triage — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (already in .gitignore).
# =============================================================

# Anthropic API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# Google Sheets ID
# Found in the Sheet URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================
# NOTE: Gmail OAuth2, Google Sheets OAuth2, and Anthropic API
# credentials are stored securely inside n8n (encrypted with
# N8N_ENCRYPTION_KEY). Only the values above are needed
# outside of n8n.
# =============================================================
